UPLOAD_FOLDER=uploads
OUTPUT_FOLDER=outputs
TEMPLATES_FOLDER=templates_data
DRAFT_TEMPLATES_FOLDER=draft_templates
DATABASE_PATH=data/mockup_catalog.sqlite3
MAX_CONTENT_LENGTH=16777216
ENABLE_SIMPLE_MODE=true
ENABLE_PSD_MODE=false
ENABLE_AI_MODE=false
# Required before opening the private admin interface.
SECRET_KEY=replace-with-a-long-random-secret
ADMIN_PASSWORD=replace-with-a-private-admin-password

# Frame detection provider: vertex, classic, or local.
DETECTION_PROVIDER=vertex
VERTEX_PROJECT_ID=vertextai-project-497513
VERTEX_LOCATION=global
VERTEX_MODEL=gemini-2.5-flash
VERTEX_MEDIA_RESOLUTION=high
VERTEX_AUTH_MODE=adc
# ai_only keeps the reliable Vertex rectangle; hybrid is an experimental guarded local edge snap.
DETECTION_REFINEMENT=ai_only
# Optional provider that accepts image_base64 JSON and returns artwork_area JSON.
LOCAL_DETECTION_URL=
LOCAL_DETECTION_MODEL=
LOCAL_DETECTION_API_KEY=

# Set comma-separated browser origins only when an external frontend needs CORS.
CORS_ORIGINS=
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false
